# ==========================================
# قاعدة البيانات (LOCAL فقط)
# ==========================================
DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=nasab_db
DB_USER=root
DB_PASSWORD=Root@Secure123

# ==========================================
# إعدادات الإنتاج (Render / Vercel)
# ==========================================
# ⚠️ هذه القيم تستخدمها في Render فقط
# ولا تعتمد على localhost أبداً في الإنتاج

NODE_ENV=production
PORT=10000

# بيانات قاعدة البيانات في Render (أو MySQL خارجي)
# عدلها حسب السيرفر الحقيقي عندك
DB_HOST=sql12.freesqldatabase.com
DB_PORT=3306
DB_NAME=sql12827422
DB_USER=sql12827422
DB_PASSWORD=GTfa7Xtnjs

# ==========================================
# الأمان
# ==========================================
JWT_SECRET=SuperSecretKey_ChangeInProduction_2026
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ==========================================
# الواجهة الأمامية
# ==========================================
FRONTEND_URL=https://nasab-tree.vercel.app
API_PREFIX=/api

# ==========================================
# الملفات
# ==========================================
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png

# ==========================================
# Firebase (اختياري)
# ==========================================
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ==========================================
# SMTP (اختياري)
# ==========================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=