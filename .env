# ==========================================
# إعدادات قاعدة البيانات (للتشغيل المحلي)
# ==========================================
# نستخدم localhost لأننا نشغّل الـ Backend خارج شبكة Docker
# المنفذ 3307 هو المنفذ الخارجي الذي فتحناه في docker-compose.yml
DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=nasab_db
DB_USER=root
DB_PASSWORD=Root@Secure123

# ==========================================
# إعدادات التطبيق والأمان
# ==========================================
NODE_ENV=development
JWT_SECRET=SuperSecretKey_ChangeInProduction_2026
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ==========================================
# إعدادات الواجهة الأمامية والروابط
# ==========================================
FRONTEND_URL=http://localhost:5173
API_PREFIX=/api

# ==========================================
# إعدادات رفع الملفات والوثائق
# ==========================================
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png

# ==========================================
# إعدادات الإشعارات (Firebase - اختياري حالياً)
# ==========================================
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ==========================================
# إعدادات البريد الإلكتروني (اختياري حالياً)
# ==========================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=