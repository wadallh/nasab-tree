# ==========================================
# 🌐 بيئة التشغيل والخادم
# ==========================================
NODE_ENV=production
PORT=3000

# ==========================================
# 🔐 الأمان والمصادقة (غيّر هذه القيم فوراً!)
# ==========================================
# ⚠️ استخدم مولّد كلمات مرور عشوائية لإنشاء قيمة قوية (>32 حرف)
# مثال: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_super_secure_random_string_64_chars_minimum
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ==========================================
# 🗄️ قاعدة البيانات السحابية (MySQL)
# ==========================================
# ⚠️ استبدل هذه القيم ببيانات قاعدة البيانات السحابية الخاصة بك
# (من Railway / Aiven / PlanetScale / إلخ)
DB_HOST=your-cloud-mysql-host.railway.app
DB_PORT=3306
DB_NAME=nasab_db
DB_USER=your_cloud_db_user
DB_PASSWORD=your_strong_cloud_db_password

# ==========================================
# 🔗 روابط الواجهة الأمامية وـ CORS
# ==========================================
# أضف نطاقات النشر الفعلية هنا (بدون مسافات بعد الفاصلة)
ALLOWED_ORIGINS=https://nasab-tree.vercel.app,https://yourdomain.com

# ==========================================
# 📤 رفع الملفات والتخزين
# ==========================================
MAX_FILE_SIZE=10485760
# ⚠️ ملاحظة: في الاستضافة السحابية، استخدم Cloudinary أو S3 بدلاً من المسار المحلي
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png

# ==========================================
# 🔔 الإشعارات (اختياري - Firebase)
# ==========================================
# FCM_PROJECT_ID=your-firebase-project-id
# FCM_PRIVATE_KEY=your-firebase-private-key
# FCM_CLIENT_EMAIL=your-firebase-client-email

# ==========================================
# 📧 البريد الإلكتروني (اختياري - للإشعارات)
# ==========================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password